# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
wheels/
pip-wheel-metadata/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Trained model weights (large binary files) ───────────────────────────────
saved_model/*.keras
saved_model/*.h5
saved_model/*.weights.h5

# Keep the directory and logs
!saved_model/.gitkeep
saved_model/logs/

# ── Preprocessed data arrays (reproducible from raw data) ────────────────────
saved_data/*.npy

# Keep the vocab — required for inference
!saved_data/word2idx.json
!saved_data/.gitkeep

# ── TensorBoard / training logs ───────────────────────────────────────────────
saved_model/logs/
*.tfevents.*
*.csv

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Testing / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
